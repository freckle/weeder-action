{
  "name": "weeder-action",
  "version": "0.0.0",
  "type": "module",
  "description": "Action description",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc --noEmit && esbuild src/main.ts --bundle --platform=node --target=node20 --outfile=dist/index.js --minify",
    "format": "prettier --write \"**/*.ts\"",
    "format-check": "prettier --check \"**/*.ts\"",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "lint": "eslint",
    "readme": "npx action-docs -u && prettier --write README.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freckle/weeder-action.git"
  },
  "author": "Freckle",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^2.0.3",
    "@actions/exec": "^2.0.0",
    "@actions/tool-cache": "^4.0.0",
    "@types/semver": "^7.7.1",
    "@types/temp": "^0.9.4",
    "semver": "^7.7.4",
    "temp": "^0.9.4"
  },
  "devDependencies": {
    "@types/node": "^24.12.0",
    "action-docs": "^2.5.1",
    "esbuild": "^0.27.4",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.1",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
