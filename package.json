{
  "name": "weeder-action",
  "version": "0.0.0",
  "type": "module",
  "description": "Action description",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && ncc build lib/main.js --minify",
    "format": "prettier --write \"**/*.ts\"",
    "format-check": "prettier --check \"**/*.ts\"",
    "test": "vitest run",
    "lint": "eslint",
    "readme": "npx action-docs -u && prettier --write README.md"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/freckle/weeder-action.git"
  },
  "author": "Freckle",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^3.0.1",
    "@actions/exec": "^3.0.0",
    "@actions/tool-cache": "^4.0.0",
    "@types/semver": "^7.7.1",
    "@types/temp": "^0.9.4",
    "semver": "^7.8.4",
    "temp": "^0.9.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.13.2",
    "@vercel/ncc": "^0.44.0",
    "action-docs": "^2.5.1",
    "eslint": "^10.5.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "vitest": "^4.1.9"
  }
}
